# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Ruff linter cache
.ruff_cache/

# Sensitive files (API keys / credentials)
**/*api_key*
*.key
*.pem
*.p12
*.pfx
.env
.env.*

# Ignore all example artifacts
examples/*
!examples/.gitkeep

# Ignore config except the shared baseline configs
config/*
!config/general_config.yaml
!config/subtitle_style.yaml

# Ignore tools content but keep directory placeholder
tools/*
!tools/.gitkeep

# Ignore outputs content but keep directory placeholder
outputs/*
!outputs/.gitkeep

# Ignore vs code settings
.vscode/*

# Ignore archived files
archive/
!archive/.gitkeep

# Ignore video files
*.mp4
*.avi
*.mov
*.mkv
*.webm
